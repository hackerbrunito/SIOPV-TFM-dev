# SIOPV Configuration
# Copy this file to .env and fill in your values

# === Application ===
SIOPV_APP_NAME=SIOPV
SIOPV_ENVIRONMENT=development
SIOPV_DEBUG=false
SIOPV_LOG_LEVEL=INFO

# === Anthropic (Claude) - REQUIRED ===
SIOPV_ANTHROPIC_API_KEY=sk-ant-xxx
SIOPV_CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
SIOPV_CLAUDE_SONNET_MODEL=claude-sonnet-4-6
SIOPV_LLM_MAX_CONTEXT_LENGTH=6000
SIOPV_LLM_ANALYSIS_MAX_TOKENS=1024
SIOPV_LLM_CONFIDENCE_MAX_TOKENS=128
SIOPV_HAIKU_MAX_TEXT_LENGTH=4000
SIOPV_HAIKU_MAX_TOKENS=512
SIOPV_HAIKU_VALIDATION_MAX_TOKENS=10
SIOPV_HAIKU_MIN_SHORT_TEXT_LENGTH=20

# === DLP / Presidio ===
# Presidio requires a spaCy NLP model for named entity recognition.
# Install with: uv pip install https://github.com/explosion/spacy-models/releases/download/en_core_web_lg-3.8.0/en_core_web_lg-3.8.0-py3-none-any.whl

# === NVD API (Optional, increases rate limit) ===
# Get free key at: https://nvd.nist.gov/developers/request-an-api-key
SIOPV_NVD_API_KEY=
SIOPV_NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
SIOPV_NVD_RATE_LIMIT_WITH_KEY=50
SIOPV_NVD_RATE_LIMIT_WITHOUT_KEY=5
SIOPV_NVD_RATE_LIMIT_PERIOD_SECONDS=30.0
SIOPV_NVD_TIMEOUT_CONNECT=5.0          # HTTP connect timeout for NVD API (seconds)
SIOPV_NVD_TIMEOUT_READ=30.0            # HTTP read timeout for NVD API (seconds)
SIOPV_NVD_TIMEOUT_WRITE=5.0            # HTTP write timeout for NVD API (seconds)
SIOPV_NVD_TIMEOUT_POOL=5.0             # HTTP connection pool timeout for NVD API (seconds)
SIOPV_NVD_MAX_CONCURRENT=5             # Max concurrent NVD API requests

# === GitHub (Optional, for Security Advisories) ===
# Create token at: https://github.com/settings/tokens
SIOPV_GITHUB_TOKEN=
SIOPV_GITHUB_GRAPHQL_URL=https://api.github.com/graphql
SIOPV_GITHUB_RATE_LIMIT_WITH_TOKEN=5000
SIOPV_GITHUB_RATE_LIMIT_WITHOUT_TOKEN=60
SIOPV_GITHUB_RATE_LIMIT_PERIOD_SECONDS=3600.0
SIOPV_GITHUB_TIMEOUT_CONNECT=5.0       # HTTP connect timeout for GitHub API (seconds)
SIOPV_GITHUB_TIMEOUT_READ=30.0         # HTTP read timeout for GitHub API (seconds)
SIOPV_GITHUB_TIMEOUT_WRITE=5.0         # HTTP write timeout for GitHub API (seconds)
SIOPV_GITHUB_TIMEOUT_POOL=5.0          # HTTP connection pool timeout for GitHub API (seconds)

# === EPSS API ===
SIOPV_EPSS_BASE_URL=https://api.first.org/data/v1/epss
SIOPV_EPSS_RATE_LIMIT_RPS=10.0
SIOPV_EPSS_BURST_SIZE=20
SIOPV_EPSS_TIMEOUT_CONNECT=5.0         # HTTP connect timeout for EPSS API (seconds)
SIOPV_EPSS_TIMEOUT_READ=15.0           # HTTP read timeout for EPSS API (seconds)
SIOPV_EPSS_TIMEOUT_WRITE=5.0           # HTTP write timeout for EPSS API (seconds)
SIOPV_EPSS_TIMEOUT_POOL=5.0            # HTTP connection pool timeout for EPSS API (seconds)
SIOPV_EPSS_BATCH_CHUNK_SIZE=100        # Max CVEs per EPSS batch request

# === Tavily Search (Optional, for OSINT fallback) ===
# Get key at: https://tavily.com
SIOPV_TAVILY_API_KEY=
SIOPV_TAVILY_BASE_URL=https://api.tavily.com/search

# === Rate Limiter ===
SIOPV_RATE_LIMITER_MAX_QUEUE_SIZE=100

# === Jira Integration (Optional) ===
SIOPV_JIRA_BASE_URL=https://your-domain.atlassian.net
SIOPV_JIRA_EMAIL=your-email@example.com
SIOPV_JIRA_API_TOKEN=
SIOPV_JIRA_PROJECT_KEY=SEC
SIOPV_JIRA_ISSUE_TYPE=Task  # Jira issue type (Task, Bug, Story — must exist in your project)

# === ChromaDB (Vector Store) ===
SIOPV_CHROMA_PERSIST_DIR=./chroma_data
SIOPV_CHROMA_COLLECTION_NAME=siopv_embeddings
SIOPV_CHROMA_CACHE_SIZE_MB=4096

# === Database ===
SIOPV_DATABASE_URL=sqlite+aiosqlite:///./siopv.db
SIOPV_CHECKPOINT_DB_PATH=siopv_checkpoints.db  # LangGraph SQLite checkpointer file path

# === OpenFGA (Optional, for authorization) ===
SIOPV_OPENFGA_API_URL=
SIOPV_OPENFGA_STORE_ID=

# --- Model Version Pinning (recommended) ---
SIOPV_OPENFGA_AUTHORIZATION_MODEL_ID=

# --- Authentication Method ---
# Options: "none" (default), "api_token" (pre-shared key), "client_credentials" (OIDC)
SIOPV_OPENFGA_AUTH_METHOD=none

# --- Pre-Shared Key Auth ---
SIOPV_OPENFGA_API_TOKEN=

# --- OIDC Auth via Keycloak (SIOPV → OpenFGA) ---
SIOPV_OPENFGA_CLIENT_ID=
SIOPV_OPENFGA_CLIENT_SECRET=
SIOPV_OPENFGA_API_AUDIENCE=
SIOPV_OPENFGA_API_TOKEN_ISSUER=

# === OIDC Authentication (API clients → SIOPV) ===
SIOPV_OIDC_ENABLED=false
SIOPV_OIDC_ISSUER_URL=
SIOPV_OIDC_AUDIENCE=
SIOPV_OIDC_JWKS_CACHE_TTL_SECONDS=3600
SIOPV_OIDC_ALLOWED_CLOCK_SKEW_SECONDS=30

# === OpenFGA OIDC Configuration (docker-compose) ===
OPENFGA_AUTHN_METHOD=preshared
OPENFGA_AUTHN_OIDC_ISSUER=http://keycloak:8080/realms/siopv
OPENFGA_AUTHN_OIDC_AUDIENCE=openfga-api

# === Uncertainty Threshold (spec section 3.4) ===
SIOPV_UNCERTAINTY_THRESHOLD=0.3
SIOPV_CONFIDENCE_FLOOR=0.7
SIOPV_ADAPTIVE_PERCENTILE=90
SIOPV_DISCREPANCY_HISTORY_SIZE=500
SIOPV_DEFAULT_CONFIDENCE=0.5

# === Human-in-the-Loop Timeouts (hours) ===
SIOPV_HITL_TIMEOUT_LEVEL1_HOURS=4
SIOPV_HITL_TIMEOUT_LEVEL2_HOURS=8
SIOPV_HITL_TIMEOUT_LEVEL3_HOURS=24
SIOPV_REVIEW_DEADLINE_HOURS=24

# === ML Model ===
SIOPV_MODEL_PATH=./models/xgboost_risk_model.json
SIOPV_MODEL_BASE_PATH=./models
SIOPV_MODEL_MAX_SIZE_BYTES=104857600
SIOPV_MODEL_SIGNING_KEY=

# === Circuit Breaker ===
SIOPV_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SIOPV_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# === PDF Output (Phase 8) ===
SIOPV_OUTPUT_DIR=./output
SIOPV_PDF_INCLUDE_COT=false

# === API Client Cache ===
SIOPV_API_CLIENT_CACHE_MAX_SIZE=1000   # Max entries in API client response cache
